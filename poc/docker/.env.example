# .env.example
# AM Platform POC Docker Compose Environment Variables

# ================================
# PostgreSQL
# ================================
POSTGRES_DB=am_db
POSTGRES_USER=am_user
POSTGRES_PASSWORD=am_password

# ================================
# MongoDB
# ================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin_password

# ================================
# NiFi
# ================================
NIFI_ADMIN_USER=nifiadmin
NIFI_ADMIN_PASS=nifipassword123!

# ================================
# Grafana
# ================================
GRAFANA_ADMIN_PASS=admin

# ================================
# Application Custom Settings
# ================================
TPS_LIMIT_SMS=500
TPS_LIMIT_MMS=300
TPS_LIMIT_RCS=400
TPS_LIMIT_FAX=200
TPS_LIMIT_EMAIL=600

# Default Retry Counts
MAX_RETRY_COUNT=3
